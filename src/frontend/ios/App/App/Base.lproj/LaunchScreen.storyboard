    <scenes>
        <!--View Controller-->
        <scene sceneID="EHf-IW-A2E">
            <objects>
                <!--
                    v118.14 — plain cream LaunchScreen, no K-mark.
                    The K-mark used to live in <imageView image="Splash">
                    here, but that gave a stale static-logo moment before
                    the webview's animated NativeSplashOverlay could take
                    over (light/dark variant by clock time). Now the
                    native LaunchScreen is just the cream background and
                    the webview overlay paints the entire branded splash.
                    The Splash.imageset file stays in Assets.xcassets but
                    is no longer referenced — Xcode will dead-strip it.
                -->
                <viewController id="01J-lp-oVM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="snD-IY-ifK">
                        <rect key="frame" x="0.0" y="0.0" width="375" height="667"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" red="0.95686274509803926" green="0.94117647058823528" blue="0.90980392156862744" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="iYj-Kq-Ea1" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="53" y="375"/>
        </scene>
    </scenes>
</document>
