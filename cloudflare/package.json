{
  "name": "uk-crm",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply kamizo-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply kamizo-db --remote",
    "db:schema": "wrangler d1 execute kamizo-db --local --file=schema.sql",
    "db:schema:prod": "wrangler d1 execute kamizo-db --remote --file=schema.sql",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.78.0"
  }
}
